{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "open.mp component",
      "description": "Build CEF for open.mp.",
      "binaryDir": "${sourceParentDir}/../target/openmp-component-build",
      "cacheVariables": {
        "SAMP_CEF_ENABLE_GRPC_EXT": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "targets": [
        "cef"
      ]
    }
  ]
}
